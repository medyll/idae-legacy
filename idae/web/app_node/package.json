{
  "name": "app_idae",
  "version": "1.0.0",
  "description": "Idae Legacy Node Server (Modernized)",
  "type": "module",
  "main": "src/main.js",
  "scripts": {
    "start": "node src/main.js",
    "dev": "nodemon src/main.js",
    "logs": "powershell Get-Content ../../../logs/php-error.log -Wait",
    "build:css": "sass ../appcss/scss/main.scss ../appcss/dist/main.css --style=compressed --no-source-map",
    "watch:css": "sass --watch ../appcss/scss/main.scss ../appcss/dist/main.css --style=expanded"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "commander": "^14.0.3",
    "cookie": "^1.1.1",
    "cron": "^4.4.0",
    "dotenv": "^17.3.1",
    "mongodb": "^7.1.0",
    "qs": "^6.15.0",
    "express": "^4.18.2",
    "socket.io": "^4.8.3",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.14",
    "sass": "^1.97.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "author": "Mydde",
  "license": "ISC"
}
