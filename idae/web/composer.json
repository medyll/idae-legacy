{
  "config":{
    "disable-tls": true,
    "secure-http": false,
    "platform-check": false,
    "audit": {
      "ignore": ["PKSA-5rsx-p2fk-h2gr"]
    }
  },
  "require": {
    "wisembly/elephant.io": "3.1.0",
    "rase/socket.io-emitter": "0.7.0",
    "ddeboer/imap": "0.5.2",
    "smarty/smarty": "v3.1.30",
    "latte/latte": "v2.4.2",
    "altorouter/altorouter": "v1.2.0",
    "mongodb/mongodb": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "AppCommon\\": "appclasses/appcommon/"
    },
    "classmap": [
      "appclasses/"
    ]
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "phpstan/phpstan": "^1.12"
  },
  "autoload-dev": {
    "psr-4": {
      "Idae\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit"
  }
}
